# CockroachDB Connection
CRDB_HOST=your-cluster.aws-us-west-2.cockroachlabs.cloud
CRDB_PORT=26257
CRDB_USER=your_username
CRDB_PASSWORD=your_password
CRDB_DATABASE=vectortest
CRDB_SSLMODE=verify-full
CRDB_SSLROOTCERT=/path/to/your/ca.crt

# Alternatively, set the full DSN directly:
# CRDB_DSN=postgresql://user:pass@host:26257/vectortest?sslmode=verify-full

# Test Configuration
VECTOR_DIM=1536
DATASET_SIZES=50000,100000,250000,500000
QUERY_COUNT=1000
TOP_K=10
ITERATIONS=3
BATCH_SIZE=25
CONCURRENCY_LEVELS=1,5,10
FRESHNESS_TRIALS=100
